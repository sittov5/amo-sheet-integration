# Скопируй в .env и заполни реальными значениями

# ── amoCRM ───────────────────────────────────────────────────
AMO_DOMAIN=yourcompany.amocrm.ru
AMO_TOKEN=your_long_lived_access_token

# ID воронки
PIPELINE_ID=123456

# ID менеджеров через запятую (порядок = порядок блоков в таблице)
MANAGER_IDS=111111,222222,333333

# ID статусов этапов воронки
STATUS_HOT_LEADS=1001
STATUS_TAKEN_TO_WORK=1002
STATUS_DATA_RECEIVED=1003
STATUS_KP_SENT=1004
STATUS_AGREED=1005
STATUS_CONFIRMED=1006
STATUS_REJECTED=142   # 142 — стандартный ID "Закрыто и не реализовано" в amoCRM

# ── Google Sheets ─────────────────────────────────────────────
# ID таблицы из URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Путь к JSON-ключу сервисного аккаунта (скачивается из Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials.json

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlmNoPQRsTUvWxYz
# Один или несколько chat_id через запятую (группы, личные чаты, каналы)
TELEGRAM_CHAT_IDS=-100123456789,486797180
